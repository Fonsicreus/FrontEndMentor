{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "includes": [
        "**",
        "!**/dist",
        "!**/node_modules",
        "!**/*.css"
      ]
  },

  "formatter": {
    "enabled": false
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "suspicious": {
        "noArrayIndexKey": "off"
      },

      "a11y": {
        "useButtonType": "off"
      }
    }
  },

  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }

}